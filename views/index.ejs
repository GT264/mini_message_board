<html>
  <head>
    <title><%= title %></title>
  </head>
  <body>
    <ul>
      <% messages.forEach((message) => { %>
        <li>Message: <%= message.text %></li>
        <li>User: <%= message.user %></li>
        <li>Added at: <%= message.added %></li>
        <hr>
      <% }); %>
    </ul>
    <a href="/new">New Message</a>
  </body>
</html>